Algoritmo Ejercicio2
	Definir producto, subtotal Como Real
	Definir unidad como entero
	Escribir "INGRESE EL PRECIO DEL PRODUCTO "
	leer producto
	Escribir "CUANTAS UNIDADES COMPRASTE? "
	leer unidad
	subtotal<- producto * unidad
	escribir "EL SUBTOTAL SIN IVA ES $", subtotal
	escribir "EL TOTAL CON IVA ES $", subtotal * 1.21
FinAlgoritmo