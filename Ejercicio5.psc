Algoritmo Ejercicio5
	definir pesos, valordolar, valoreuro Como real
	
	Escribir "Dame la cantidad de Pesos "
	leer pesos
	Escribir "Cuanto vale el Dolar en pesos? "
	leer valordolar
	Escribir "Cuanto vale el Euro en pesos? "
	leer valoreuro
	escribir "Tus Pesos equivalen a ", pesos / valordolar " Dolares"
	escribir "Tus Pesos equivalen a ", pesos / valoreuro " Euros"
FinAlgoritmo